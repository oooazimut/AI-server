[Unit]
Description=AI Server Agent Worker
After=network.target postgresql.service redis.service
Wants=postgresql.service redis.service

[Service]
Type=exec
WorkingDirectory=/opt/ai-server
EnvironmentFile=/opt/ai-server/.env.prod
ExecStart=/opt/ai-server/.venv/bin/python -m ai_server.agent_worker
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ai-server-worker

[Install]
WantedBy=multi-user.target
