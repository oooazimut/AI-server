# ─────────────────────────────────────────────
# Bitrix24 Bot
# ─────────────────────────────────────────────
BITRIX_BOT_ID=
BITRIX_BOT_TOKEN=
# webhook | oauth
BITRIX_BOT_AUTH_MODE=webhook
BITRIX_BOT_OAUTH_USER_ID=
BITRIX_BOT_WEBHOOK_URL=
BITRIX_DOMAIN=
BITRIX_OAUTH_CLIENT_ID=
BITRIX_OAUTH_CLIENT_SECRET=
BITRIX_OAUTH_ENABLED=true
BITRIX_OAUTH_REQUIRED_FOR_WRITES=true
BITRIX_OAUTH_APP_PATH=/bitrix/app
BITRIX_OAUTH_CALLBACK_PATH=/bitrix/oauth/callback
BITRIX_OAUTH_DB_PATH=
BITRIX_OAUTH_TOKEN_ENDPOINT=https://oauth.bitrix.info/oauth/token/
BITRIX_REST_WEBHOOK_URL=
BITRIX_PROJECTS_WEBHOOK_URL=

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PUBLIC_BASE_URL=
WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# LLM
# ─────────────────────────────────────────────
AI_SERVER_LLM_PROVIDER=deepseek
AI_SERVER_LLM_MODEL=deepseek-v4-flash
AI_SERVER_LLM_BASE_URL=
AI_SERVER_LLM_API_KEY=
AI_SERVER_LLM_TEMPERATURE=
AI_SERVER_LLM_MAX_TOKENS=3000
# Если провайдер не deepseek, задайте ключ явно:
AI_SERVER_DEEPSEEK_API_KEY=
# Краткие алиасы (приоритет над AI_SERVER_LLM_* если заданы):
LLM_PROVIDER=
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_TEMPERATURE=
LLM_MAX_TOKENS=
DEEPSEEK_API_KEY=
# DeepSeek биллинг (для tech footer):
AI_SERVER_DEEPSEEK_BALANCE_BASE_URL=https://api.deepseek.com
AI_SERVER_DEEPSEEK_BALANCE_TIMEOUT_SECONDS=10

# ─────────────────────────────────────────────
# Technical footer (debug info в чате)
# ─────────────────────────────────────────────
AI_SERVER_TECH_FOOTER_ENABLED=true
# Через запятую — ID пользователей Bitrix, которым виден footer
AI_SERVER_TECH_FOOTER_ALLOWED_USER_IDS=
AI_SERVER_TECH_FOOTER_BALANCE_ENABLED=true
AI_SERVER_TECH_FOOTER_BALANCE_CACHE_SECONDS=300

# ─────────────────────────────────────────────
# Yandex Cloud (SpeechKit + биллинг)
# ─────────────────────────────────────────────
YANDEX_API_KEY=
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=
YANDEX_SPEECHKIT_BASE_URL=https://stt.api.cloud.yandex.net
YANDEX_SPEECHKIT_LANG=ru-RU
YANDEX_SPEECHKIT_MAX_BYTES=1048576
YANDEX_SPEECHKIT_CONVERT_TO_OGG=true

# Биллинг-аккаунт Yandex Cloud (для tech footer)
YANDEX_BILLING_ACCOUNT_ID=
YANDEX_BILLING_IAM_TOKEN=
YANDEX_BILLING_BASE_URL=https://billing.api.cloud.yandex.net

# ─────────────────────────────────────────────
# STT / транскрипция
# ─────────────────────────────────────────────
STT_PROVIDER=yandex_speechkit
TRANSCRIPTION_MAX_BYTES=26214400
FFMPEG_PATH=ffmpeg
ATTACHMENT_MAX_BYTES=31457280

# ─────────────────────────────────────────────
# Webhook event queue
# ─────────────────────────────────────────────
WEBHOOK_EVENT_QUEUE_ENABLED=true
AI_SERVER_WEBHOOK_EVENT_WORKER_ENABLED=false
DIAGNOST_ENABLED=true
WEBHOOK_EVENT_QUEUE_INTERVAL_SECONDS=2
WEBHOOK_EVENT_QUEUE_WORKER_COUNT=1
WEBHOOK_EVENT_QUEUE_MAX_ATTEMPTS=8
WEBHOOK_EVENT_QUEUE_RETRY_BASE_SECONDS=10
WEBHOOK_EVENT_QUEUE_RETRY_MAX_SECONDS=300
WEBHOOK_EVENT_QUEUE_CLAIM_SCAN_LIMIT=50
WEBHOOK_EVENT_QUEUE_STALE_PROCESSING_SECONDS=300

# ─────────────────────────────────────────────
# Поиск по порталу (индексатор)
# ─────────────────────────────────────────────
SEARCH_BACKGROUND_INDEXER_ENABLED=false
SEARCH_BACKGROUND_INITIAL_DELAY_SECONDS=60
SEARCH_BACKGROUND_METADATA_INTERVAL_SECONDS=21600
SEARCH_BACKGROUND_CONTENT_INTERVAL_SECONDS=600
SEARCH_BACKGROUND_LOCK_STALE_SECONDS=7200
SEARCH_DELTA_INDEXER_ENABLED=true
SEARCH_DELTA_INTERVAL_SECONDS=300
SEARCH_DELTA_FOLDERS_PER_RUN=15
SEARCH_DELTA_MAX_CHILDREN_PER_FOLDER=1000
SEARCH_WEBHOOK_INDEXER_ENABLED=false
SEARCH_WEBHOOK_CONTENT_ENABLED=true
SEARCH_CONTENT_ENABLED=true
SEARCH_CONTENT_ALLOWED_EXTENSIONS=.txt,.csv,.doc,.docx,.xlsx,.xls,.pdf
SEARCH_CONTENT_MAX_BYTES=20971520
SEARCH_CONTENT_MAX_CHARS=40000
SEARCH_CONTENT_MAX_FILES=80
SEARCH_CONTENT_KEEP_LOCAL_FILES=false
SEARCH_INDEX_MAX_TASKS=5000
SEARCH_INDEX_MAX_PROJECTS=200
SEARCH_INDEX_MAX_DISK_ITEMS=50000
SEARCH_INDEX_INCLUDE_DISK=true
SEARCH_INDEX_INCLUDE_TASK_ATTACHMENTS=true
SEARCH_INDEX_MAX_STORAGES=500
SEARCH_INDEX_MAX_TASK_ATTACHMENTS=5000
SEARCH_INDEX_DISK_MAX_DEPTH=6

# ─────────────────────────────────────────────
# Quality control (контроль задач)
# ─────────────────────────────────────────────
QUALITY_CONTROL_WEBHOOK_ENABLED=false
QUALITY_CONTROL_DRY_RUN=true
QUALITY_CONTROL_NOTIFY_ONLY=false
QUALITY_CONTROL_SMART_ENABLED=true
QUALITY_CONTROL_DIRECTOR_USER_ID=
QUALITY_CONTROL_ADDITIONAL_NOTIFY_USER_IDS=
QUALITY_CONTROL_EXEMPT_RESPONSIBLE_USER_IDS=
QUALITY_CONTROL_ACTOR_USER_ID=
QUALITY_CONTROL_AUTO_MANAGE_PROJECT_ID=
QUALITY_CONTROL_WEBHOOK_AUTO_MANAGED_ONLY=true
QUALITY_CONTROL_NOTIFY_DIRECTOR=true
QUALITY_CONTROL_NOTIFY_RESPONSIBLE=true

# ─────────────────────────────────────────────
# Supervisor (напоминания по задачам)
# ─────────────────────────────────────────────
SUPERVISOR_ENABLED=false
SUPERVISOR_DRY_RUN=true
SUPERVISOR_ADMIN_USER_IDS=
SUPERVISOR_INTERVAL_SECONDS=3600
SUPERVISOR_INITIAL_DELAY_SECONDS=60
SUPERVISOR_REMINDER_COOLDOWN_HOURS=12
SUPERVISOR_MAX_TASKS=50
SUPERVISOR_MAX_TASKS_PER_USER=10
SUPERVISOR_NOTIFY_RESPONSIBLES=false

# ─────────────────────────────────────────────
# Reconciler (сверка задач/диска)
# ─────────────────────────────────────────────
RECONCILE_ENABLED=false
RECONCILE_INTERVAL_SECONDS=900
RECONCILE_INITIAL_DELAY_SECONDS=120
RECONCILE_TASKS_ENABLED=true
RECONCILE_TASK_LIMIT=500
RECONCILE_TASK_LOOKBACK_HOURS=24
RECONCILE_DISK_DELTA_ENABLED=true

# ─────────────────────────────────────────────
# Vehicle usage (учёт служебных машин)
# ─────────────────────────────────────────────
VEHICLE_USAGE_ENABLED=false
VEHICLE_USAGE_DRY_RUN=true
VEHICLE_USAGE_MANAGER_USER_ID=
VEHICLE_USAGE_DIALOG_ID=
VEHICLE_USAGE_REQUEST_TIME=08:30
VEHICLE_USAGE_REMINDER_INTERVAL_MINUTES=30
VEHICLE_USAGE_REMINDER_DELAYS_MINUTES=30,60
VEHICLE_USAGE_MAX_REMINDERS=2
VEHICLE_USAGE_WORKDAY_MODE=weekday
VEHICLE_USAGE_UNKNOWN_FILL_TIME=12:00
VEHICLE_USAGE_AUTO_DAY_OFF_TIME=18:00
VEHICLE_USAGE_ADMIN_NOTIFY_USER_IDS=
VEHICLE_USAGE_ADMIN_USER_IDS=
VEHICLE_USAGE_ALLOWED_USER_IDS=
VEHICLE_USAGE_EXCLUDED_USER_IDS=
VEHICLE_USAGE_STAFF_SYNC_ENABLED=false
# Через запятую: employee_id:name:car_number
VEHICLE_USAGE_STAFF_ROSTER=

# ─────────────────────────────────────────────
# Агент — права и ограничения
# ─────────────────────────────────────────────
AGENT_WRITE_ALLOWED_USER_IDS=
AGENT_LIMITED_TASK_CREATE_PROJECT_ID=
AGENT_LIMITED_TASK_CREATE_USER_IDS=
AGENT_PRIVATE_DISK_PATH_MARKERS=Приватный доступ
AGENT_PRIVATE_DISK_RESTRICTED_USER_IDS=
AGENT_WORKING_DATES=
AGENT_NON_WORKING_DATES=
AGENT_DRY_RUN=false

# ─────────────────────────────────────────────
# Project Shell (для агента-Переговорщика)
# ─────────────────────────────────────────────
AGENT_SHELL_ENABLED=false
AGENT_SHELL_EXECUTABLE=pwsh
AGENT_SHELL_TIMEOUT_SECONDS=30
AGENT_SHELL_MAX_COMMAND_CHARS=500
AGENT_SHELL_MAX_OUTPUT_CHARS=4000

# ─────────────────────────────────────────────
# Learning events
# ─────────────────────────────────────────────
LEARNING_EVENTS_ENABLED=true
LEARNING_EVENTS_CAPTURE_TEXT=true
LEARNING_EVENTS_MAX_TEXT_CHARS=8000

# ─────────────────────────────────────────────
# Runtime / хранилище данных
# ─────────────────────────────────────────────
# Переопределить каталог var/ (по умолчанию — корень проекта/var)
AI_SERVER_VAR_DIR=
# Список .env-файлов через запятую (по умолчанию .env,.env.local)
AI_SERVER_ENV_FILE=.env,.env.local
