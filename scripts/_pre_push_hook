#!/usr/bin/env bash
# Pre-push hook: lint + format check before pushing.
# Copy to .git/hooks/pre-push to enable:
#   cp scripts/_pre_push_hook .git/hooks/pre-push
# Skip with: git push --no-verify

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

echo "→ ruff check..."
uv run ruff check .

echo "→ ruff format --check..."
uv run ruff format --check .

echo "✓ Pre-push checks passed"
